# Replace {$DOMAIN} with your domain, or use :80 for local HTTP-only.
{$DOMAIN:localhost} {
    encode gzip

    handle /api/* {
        reverse_proxy api:8080
    }

    handle /health {
        reverse_proxy api:8080
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
