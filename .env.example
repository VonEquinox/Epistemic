# Database
DATABASE_URL=postgres://epistemic:epistemic@localhost:5432/epistemic

# API
API_HOST=0.0.0.0
API_PORT=8080
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_SECURE=false
RUST_LOG=info,epistemic=debug

# Bootstrap first admin (only when users table is empty)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_PASSWORD=changeme123

# Paths
PDF_DIR=./data/pdfs
TEI_DIR=./data/tei

# External services
GROBID_URL=http://localhost:8070
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Embedding provider (undecided: voyage | local)
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
EMBEDDING_DIM=1024

# Semantic Scholar (optional, higher rate limits with key)
S2_API_KEY=
