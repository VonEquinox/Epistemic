# Database
DATABASE_URL=postgres://epistemic:epistemic@localhost:5432/epistemic

# API
API_HOST=0.0.0.0
API_PORT=8080
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_SECURE=false
RUST_LOG=info,epistemic=debug

# Bootstrap first admin (only when users table is empty)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_PASSWORD=changeme123

# Paths
PDF_DIR=./data/pdfs
# Optional legacy TEI dir (read-only if old parses exist). GROBID removed.
TEI_DIR=./data/tei

# LLM — OpenAI Chat Completions compatible (OpenAI / gateway / vLLM / OpenRouter / Evolvent)
# Base URL: API root with or without /v1 (client normalizes to .../v1, then /chat/completions)
# Evolvent example:
#   OPENAI_BASE_URL=http://llmapi.evolventapi.com/v1
#   OPENAI_MODEL=sub2api-gpt-5.6-terra
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
# Aliases also accepted: LLM_API_KEY, LLM_BASE_URL, LLM_MODEL
# Long timeout for full-PDF vision (seconds)
LLM_TIMEOUT_SECS=1800
# PDF → PNG for VLM (requires poppler `pdftoppm`)
PDF_RENDER_DPI=150
# Optional safety cap; unset or 0 = all pages
# PDF_MAX_PAGES=0

# Embedding — OpenAI-compatible /v1/embeddings (SiliconFlow / OpenAI / local)
# SiliconFlow example:
#   EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
#   EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
#   EMBEDDING_DIM=4096
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096

# Parallel job slots in one worker process (LLM-heavy)
WORKER_CONCURRENCY=16
